

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Client {
  id        String    @id @default(uuid())
  userName  String
  email     String    @unique
  password  String
  weight    Float
  height    Float
  age       Int
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String    @id @default(uuid())
  projectName String
  projectGoal String
  sportType   String
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions    Session[]
  createdAt   DateTime  @default(now())
}

model Session {
  id             String   @id @default(uuid())
  description    String
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  videoKey       String?
  summary        String?
  recommendation String?
}
